<idea-plugin>
    <id>com.example.hello_word_plugin</id>
    <name>Hello Word Plugin</name>

    <description><![CDATA[
        A minimal Hello Word JetBrains plugin.
    ]]></description>

    <change-notes><![CDATA[
        Initial release.
    ]]></change-notes>

    <idea-version since-build="242"/>

    <depends>com.intellij.modules.platform</depends>

    <actions>
        <action
                id="com.example.hello_word_plugin.HelloWordPluginApplication"
                class="com.example.hello_word_plugin.HelloWordPluginApplication"
                text="Hello Word"
                description="Shows a Hello Word dialog">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>
    </actions>
</idea-plugin>