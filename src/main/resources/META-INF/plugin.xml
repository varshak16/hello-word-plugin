<idea-plugin>
    <id>hello_word</id>
    <name>Hello Word</name>

    <vendor email="integrations@moole.ai" url="https://github.com/varshak16">Moole Platform X</vendor>

    <description><![CDATA[
    A minimal IntelliJ IDEA extension designed to demonstrate the integration of
    Spring Boot and the IntelliJ Platform SDK. It provides a simple 'Hello Word'
    action for developers to test their environment and explore custom actions.
    ]]></description>

    <change-notes><![CDATA[
        Initial release.
    ]]></change-notes>

    <idea-version since-build="242"/>

    <depends>com.intellij.modules.platform</depends>

    <actions>
        <action
                id="com.example.hello_word_plugin.HelloWordPluginApplication"
                class="com.example.hello_word_plugin.HelloWordPluginApplication"
                text="Hello Word"
                description="Shows a Hello Word dialog">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>
    </actions>
</idea-plugin>